# =============================================================================
# Environment variables — security model
# =============================================================================
#
# CLIENT (browser bundle) — prefix with VITE_
#   - Embedded in JS at build time; anyone can read them in DevTools / dist/.
#   - Safe: public URLs (Convex deployment URL is designed to be public).
#   - NEVER: passwords, SMTP creds, API keys, private tokens.
#
# SERVER (local dev / vite preview only) — EMAIL_* with NO VITE_ prefix
#   - Read only by vite.config.ts → vite-api-plugin (Node middleware).
#   - Not imported from src/ and not present in dist/ after `npm run build`.
#   - For production email OTP, move sending to Convex actions/http or a backend.
#
# Files: copy to `.env` or `.env.local` (both are gitignored).
# =============================================================================

# --- Client (VITE_*) ---
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# --- Server OTP (must match Convex: `npx convex env set OTP_INTERNAL_SECRET <value>`) ---
OTP_INTERNAL_SECRET=generate-a-long-random-string

# --- Server (EMAIL_*) — local dev uses Vite middleware; production uses Convex HTTP + these on Convex env ---
# Set the same EMAIL_* and OTP_INTERNAL_SECRET values in Convex for production sign-in/sign-up:
#   npx convex env set OTP_INTERNAL_SECRET <value>
#   npx convex env set EMAIL_USER <value>
#   npx convex env set EMAIL_PASS <value>
#   (optional) npx convex env set EMAIL_HOST smtp.gmail.com
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM=you@gmail.com
EMAIL_FROM_NAME=Palawan Wildlife Rescue

# Optional SMTP overrides (recommended for Gmail: port 465 or omit EMAIL_PORT)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
# EMAIL_FORCE_IPV4=true

# Gmail App Password: https://myaccount.google.com/apppasswords
# Restart `npm run dev` after changes. Look for "[pwrrc-api] SMTP verified" in the terminal.

# --- Rate limiting for auth endpoints ---
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=10

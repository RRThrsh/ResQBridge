{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["jest", "@testing-library/jest-dom", "node"],
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": false,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "noEmit": true
  },
  "include": [
    "tests",
    "src",
    "convex",
    "vite-otp-store.ts",
    "jest.config.cjs"
  ]
}
